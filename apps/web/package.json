{
  "name": "@osdrive/web",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "wrangler types --cwd src && vite build",
    "start": "vite start",
    "preview": "vite preview",
    "typecheck": "tsgo --noEmit",
    "db:generate": "drizzle-kit generate",
    "deploy:prod": "pnpm build && wrangler deploy",
    "migrate:prod": "npx wrangler d1 migrations apply osdrive --remote",
    "migrate:local": "npx wrangler d1 migrations apply osdrive --local"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.5.6",
    "@effect/opentelemetry": "4.0.0-beta.46",
    "@fontsource-variable/geist": "^5.2.8",
    "@kobalte/core": "^0.13.11",
    "@opentelemetry/exporter-trace-otlp-http": "^0.211.0",
    "@opentelemetry/sdk-trace-base": "^2.6.1",
    "@opentelemetry/sdk-trace-web": "^2.6.1",
    "@paralleldrive/cuid2": "^3.3.0",
    "@solidjs/meta": "^0.29.4",
    "@solidjs/router": "^0.15.0",
    "@solidjs/start": "2.0.0-alpha.2",
    "@t3-oss/env-core": "^0.13.11",
    "@tailwindcss/vite": "^4.2.2",
    "better-auth": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "effect": "4.0.0-beta.46",
    "lucide-react": "^1.7.0",
    "lucide-solid": "^1.7.0",
    "posthog-js": "^1.364.7",
    "shadcn": "^4.1.2",
    "solid-js": "^1.9.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.31.0",
    "@types/node": "^25.5.2",
    "drizzle-kit": "^0.31.10",
    "vite": "^7.1.10",
    "vite-tsconfig-paths": "^6.1.1",
    "wrangler": "^4.80.0",
    "@typescript/native-preview": "7.0.0-dev.20260411.1"
  },
  "engines": {
    "node": ">=22"
  }
}
